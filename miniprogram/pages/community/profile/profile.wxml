<!-- 社区端个人中心 -->
<view class="profile-container">
  <!-- 头部信息 -->
  <view class="profile-header">
    <view class="user-info" bindtap="goEditProfile">
      <image src="{{userInfo.avatarUrl || '/assets/icons/avatar.png'}}" class="avatar" />
      <view class="user-text">
        <text class="nickname">{{profile.real_name || profile.nickName || '社区用户'}}</text>
        <text class="position">{{profile.position || '社区管理员'}}</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow" />
    </view>
    
    <!-- 统计 -->
    <view class="profile-stats">
      <view class="stat-item">
        <text class="stat-num">{{profile.stats.demands || 0}}</text>
        <text class="stat-label">发布需求</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{profile.stats.matches || 0}}</text>
        <text class="stat-label">撮合成功</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{profile.stats.favorites || 0}}</text>
        <text class="stat-label">我的收藏</text>
      </view>
    </view>
  </view>

  <!-- 社区信息 -->
  <view class="card community-card">
    <view class="card-header">
      <text class="card-title">社区信息</text>
      <text class="edit-btn" bindtap="goEditProfile">编辑</text>
    </view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">所属社区</text>
        <text class="info-value">{{profile.district}}{{profile.street}}{{profile.community}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">联系人</text>
        <text class="info-value">{{profile.real_name}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">联系电话</text>
        <text class="info-value">{{profile.phone}}</text>
      </view>
    </view>
  </view>

  <!-- 我的功能 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goMyDemands">
      <view class="menu-left">
        <image src="/assets/icons/demand.png" class="menu-icon" />
        <text>我的需求</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
    <view class="menu-item" bindtap="goMyResources">
      <view class="menu-left">
        <image src="/assets/icons/resource.png" class="menu-icon" />
        <text>我的发布</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <view class="menu-left">
        <image src="/assets/icons/favorite.png" class="menu-icon" />
        <text>我的收藏</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
    <view class="menu-item" bindtap="goRewards">
      <view class="menu-left">
        <image src="/assets/icons/reward.png" class="menu-icon" />
        <text>我的奖励</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
    <view class="menu-item" bindtap="goSpaces">
      <view class="menu-left">
        <image src="/assets/icons/space.png" class="menu-icon" />
        <text>场地管理</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
  </view>

  <!-- 其他功能 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goAbout">
      <view class="menu-left">
        <image src="/assets/icons/about.png" class="menu-icon" />
        <text>关于我们</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
    <view class="menu-item" bindtap="showService">
      <view class="menu-left">
        <image src="/assets/icons/service.png" class="menu-icon" />
        <text>联系客服</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
    <view class="menu-item" bindtap="showSettings">
      <view class="menu-left">
        <image src="/assets/icons/settings.png" class="menu-icon" />
        <text>设置</text>
      </view>
      <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout">
    <text>退出登录</text>
  </view>
</view>
