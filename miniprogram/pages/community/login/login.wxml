<!-- 社区端登录页面 -->
<view class="login-container">
  <!-- 顶部 -->
  <view class="login-header">
    <image src="/assets/images/logo.png" class="logo" />
    <text class="app-name">邻盟 - 社区端</text>
    <text class="app-desc">社区互助 资源共享</text>
  </view>

  <!-- 登录方式 -->
  <view class="login-content">
    <!-- 微信一键登录 -->
    <view class="wechat-login">
      <button 
        class="btn-wechat" 
        open-type="getPhoneNumber" 
        bindgetphonenumber="onGetPhoneNumber"
      >
        <text class="wechat-icon">💬</text>
        <text>微信一键登录</text>
      </button>
      <text class="login-hint">点击上方按钮授权手机号快速登录</text>
    </view>

    <!-- 其他登录方式 -->
    <view class="other-login">
      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">其他方式</text>
        <view class="divider-line"></view>
      </view>
      
      <view class="login-options">
        <view class="login-option" bindtap="showPhoneLogin">
          <image src="/assets/icons/phone.png" class="option-icon" />
          <text>手机号登录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <checkbox-group bindchange="onAgreementChange">
      <label class="agreement-label">
        <checkbox value="agree" checked="{{agreed}}" color="#409EFF" />
        <text class="agreement-text">登录即表示同意<text class="link" bindtap="showTerms">《用户协议》</text>和<text class="link" bindtap="showPrivacy">《隐私政策》</text></text>
      </label>
    </checkbox-group>
  </view>

  <!-- 手机号登录弹窗 -->
  <view class="phone-modal {{showPhoneModal ? 'show' : ''}}" catchtap="closePhoneModal">
    <view class="phone-modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">手机号登录</text>
        <icon type="clear" size="20" bindtap="closePhoneModal" />
      </view>
      
      <view class="modal-body">
        <view class="input-group">
          <input 
            type="number" 
            maxlength="11" 
            placeholder="请输入手机号" 
            bindinput="onPhoneInput"
            value="{{phone}}"
          />
        </view>
        
        <view class="input-group verify-group">
          <input 
            type="number" 
            maxlength="6" 
            placeholder="请输入验证码" 
            bindinput="onCodeInput"
            value="{{code}}"
          />
          <button 
            class="btn-code {{countdown > 0 ? 'disabled' : ''}}" 
            bindtap="sendCode"
            disabled="{{countdown > 0}}"
          >
            {{countdown > 0 ? countdown + 's' : '获取验证码'}}
          </button>
        </view>
        
        <button class="btn-login" bindtap="phoneLogin">登录</button>
      </view>
    </view>
  </view>
</view>
