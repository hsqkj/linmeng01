<!-- 资源详情页 -->
<view class="detail-container">
  <!-- 图片轮播 -->
  <swiper 
    class="image-swiper"
    indicator-dots="{{images.length > 1}}"
    autoplay="{{false}}"
    circular
  >
    <swiper-item wx:for="{{images}}" wx:key="*this">
      <image src="{{item}}" class="detail-image" mode="aspectFill" bindtap="previewImage" data-index="{{index}}" />
    </swiper-item>
  </swiper>

  <!-- 基本信息 -->
  <view class="section basic-info">
    <view class="resource-header">
      <text class="resource-title">{{resource.title}}</text>
      <view class="resource-tags">
        <text class="tag tag-primary">{{resource.typeName}}</text>
        <text class="tag tag-success" wx:if="{{resource.isFree}}">免费</text>
      </view>
    </view>
    
    <view class="resource-meta">
      <view class="meta-item">
        <text class="meta-label">浏览</text>
        <text class="meta-value">{{resource.view_count || 0}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-label">收藏</text>
        <text class="meta-value">{{resource.favorite_count || 0}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-label">分享</text>
        <text class="meta-value">{{resource.share_count || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 商家信息 -->
  <view class="section merchant-info" bindtap="goMerchantHome">
    <image src="{{resource.merchant_logo}}" class="merchant-logo" />
    <view class="merchant-text">
      <text class="merchant-name">{{resource.company_name}}</text>
      <text class="merchant-address">{{resource.merchant_address || '地址未填写'}}</text>
    </view>
    <image src="/assets/icons/arrow-right.png" class="arrow-icon" />
  </view>

  <!-- 资源详情 -->
  <view class="section detail-section">
    <text class="section-title">资源详情</text>
    <view class="detail-content">
      <text class="content-text">{{resource.content}}</text>
    </view>
    
    <!-- 扩展字段 -->
    <view class="detail-fields" wx:if="{{resource.fields && resource.fields.length > 0}}">
      <view class="field-item" wx:for="{{resource.fields}}" wx:key="label">
        <text class="field-label">{{item.label}}</text>
        <text class="field-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 位置信息 -->
  <view class="section location-section" wx:if="{{resource.merchant_lat && resource.merchant_lng}}">
    <text class="section-title">位置信息</text>
    <map 
      class="location-map"
      latitude="{{resource.merchant_lat}}"
      longitude="{{resource.merchant_lng}}"
      markers="{{markers}}"
      scale="15"
      bindtap="openMap"
    />
    <view class="location-text">
      <image src="/assets/icons/location.png" class="location-icon" />
      <text>{{resource.merchant_address || '商家地址'}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="action-left">
      <view class="action-item" bindtap="toggleFavorite">
        <image src="/assets/icons/{{isFavorited ? 'favorite-active' : 'favorite'}}.png" class="action-icon" />
        <text>{{isFavorited ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-item" bindtap="contactMerchant">
        <image src="/assets/icons/service.png" class="action-icon" />
        <text>咨询</text>
      </view>
    </view>
    <view class="action-right">
      <button class="btn-consult" open-type="contact">留言咨询</button>
      <button class="btn-match" bindtap="applyMatch">申请撮合</button>
    </view>
  </view>
</view>
