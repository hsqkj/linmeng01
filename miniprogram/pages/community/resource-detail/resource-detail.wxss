/* 资源详情页样式 */

.detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 500rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

/* 区块 */
.section {
  background: #ffffff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

/* 基本信息 */
.basic-info {
  padding: 30rpx;
}

.resource-header {
  margin-bottom: 24rpx;
}

.resource-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.resource-tags {
  display: flex;
  gap: 12rpx;
}

.resource-meta {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 8rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #666666;
}

/* 商家信息 */
.merchant-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.merchant-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
}

.merchant-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.merchant-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.merchant-address {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

/* 详情区块 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.detail-content {
  line-height: 1.8;
}

.content-text {
  font-size: 28rpx;
  color: #666666;
  white-space: pre-wrap;
}

/* 扩展字段 */
.detail-fields {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.field-item {
  display: flex;
  padding: 16rpx 0;
}

.field-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999999;
}

.field-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 位置信息 */
.location-map {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.location-text {
  display: flex;
  align-items: center;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.location-text text {
  font-size: 26rpx;
  color: #666666;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-left {
  display: flex;
  gap: 40rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
}

.action-item text {
  font-size: 22rpx;
  color: #666666;
  margin-top: 4rpx;
}

.action-right {
  display: flex;
  gap: 20rpx;
}

.btn-consult {
  height: 72rpx;
  padding: 0 36rpx;
  background: #ffffff;
  border: 2rpx solid #409EFF;
  border-radius: 36rpx;
  color: #409EFF;
  font-size: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn-match {
  height: 72rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #409EFF, #66b1ff);
  border: none;
  border-radius: 36rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  justify-content: center;
  align-items: center;
}
