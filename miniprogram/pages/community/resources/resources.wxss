/* 资源广场样式 */

.resources-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: #ffffff;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
  background: #ffffff;
  padding: 0 20rpx 20rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
}

.category-item.active {
  background: linear-gradient(135deg, #409EFF, #66b1ff);
  color: #ffffff;
}

/* 资源列表 */
.resource-list {
  height: calc(100vh - 220rpx);
  padding: 20rpx 30rpx;
}

.resource-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.15s, box-shadow 0.15s;
}

.resource-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.03);
}

.resource-images {
  width: 100%;
  height: 360rpx;
}

.placeholder-view {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.placeholder-text {
  font-size: 24rpx;
  color: #bbb;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.resource-img {
  width: 100%;
  height: 100%;
}

.resource-content {
  padding: 24rpx;
}

.resource-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.resource-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.resource-tags {
  flex-shrink: 0;
}

.resource-desc {
  font-size: 26rpx;
  color: #666666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

.resource-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.merchant-info {
  display: flex;
  align-items: center;
}

.merchant-logo {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.merchant-name {
  font-size: 24rpx;
  color: #999999;
}

.resource-actions {
  display: flex;
  gap: 32rpx;
}

.action-item {
  display: flex;
  align-items: center;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 8rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #999999;
}

/* 加载状态 */
.load-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.load-status text {
  font-size: 26rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 加载动画 */
.loading-icon-small {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #f0f0f0;
  border-top-color: #409EFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more-text {
  color: #bbb;
  font-size: 24rpx;
}
