/* 社区端首页样式 */
page {
  background: #f5f5f5;
}

.community-home {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 顶部欢迎 */
.header {
  background: linear-gradient(135deg, #1890FF 0%, #0976E5 100%);
  padding: 40rpx 30rpx 60rpx;
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-text {
  margin-left: 20rpx;
}

.greeting {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}

.community-name {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 6rpx;
}

.header-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 6rpx;
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  margin-top: -30rpx;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.action-card:active {
  transform: scale(0.95);
}

.action-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-card.publish-demand .action-icon-wrapper {
  background: rgba(24, 144, 255, 0.1);
}

.action-card.my-demand .action-icon-wrapper {
  background: rgba(82, 196, 26, 0.1);
}

.action-card.resources .action-icon-wrapper {
  background: rgba(255, 107, 0, 0.1);
}

.action-card.favorites .action-icon-wrapper {
  background: rgba(212, 160, 23, 0.1);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
}

.action-card text {
  font-size: 26rpx;
  color: #333;
}

/* 区块样式 */
.section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

/* 推荐资源横向滚动 */
.resource-scroll {
  white-space: nowrap;
}

.resource-list {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 30rpx;
}

.resource-item {
  width: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.resource-img {
  width: 100%;
  height: 160rpx;
}

.resource-info {
  padding: 20rpx;
}

.resource-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.resource-type {
  display: block;
  font-size: 24rpx;
  color: #1890FF;
  margin-top: 8rpx;
}

.resource-merchant {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 需求列表 */
.demand-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.demand-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.demand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.demand-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.demand-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
}

.tag-primary {
  background: rgba(24, 144, 255, 0.1);
  color: #1890FF;
}

.tag-danger {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.demand-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.demand-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.demand-community {
  font-size: 24rpx;
  color: #999;
}

.demand-time {
  font-size: 24rpx;
  color: #999;
}
