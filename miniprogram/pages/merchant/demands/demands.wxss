/* 需求大厅样式 */
.demands-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eee;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back image {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

.search-bar {
  background: #fff;
  padding: 16rpx 20rpx;
  margin-bottom: 0;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  white-space: nowrap;
  background: #fff;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background: #ff6b00;
  color: #fff;
}

.search-input {
  background: #f5f5f5;
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.demand-list {
  padding: 0 20rpx;
}

.demand-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.demand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.demand-type {
  display: inline-block;
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.demand-time {
  font-size: 22rpx;
  color: #999;
}

.demand-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.demand-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.demand-meta {
  display: flex;
  gap: 30rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-item image {
  width: 28rpx;
  height: 28rpx;
}

.demand-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.demand-budget {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: bold;
}

.btn-contact {
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  color: #fff;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
}

.loading-more, .no-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-icon-small {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #f0f0f0;
  border-top-color: #ff6b00;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
