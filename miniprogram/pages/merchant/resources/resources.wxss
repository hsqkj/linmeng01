/* 资源管理样式 */
.resources-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.filter-bar {
  background: #fff;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #666;
  font-size: 28rpx;
}

.filter-btn image {
  width: 28rpx;
  height: 28rpx;
}

.btn-publish {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  color: #fff;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
}

.btn-publish image {
  width: 32rpx;
  height: 32rpx;
}

.resource-list {
  padding: 0 20rpx;
}

.resource-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
  transition: transform 0.15s, box-shadow 0.15s;
}

.resource-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.resource-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.resource-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.resource-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.resource-meta {
  display: flex;
  gap: 16rpx;
}

.resource-type {
  background: #fff3e6;
  color: #ff6b00;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.resource-status {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.resource-status.active {
  background: #e6fff0;
  color: #67c23a;
}

.resource-status.inactive {
  background: #f5f5f5;
  color: #999;
}

.resource-stats {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
}

.resource-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
}

.action-btn.edit {
  background: #e6f3ff;
  color: #409eff;
}

.action-btn.delete {
  background: #fef0f0;
  color: #f56c6c;
}

.loading-more, .no-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-icon-small {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #f0f0f0;
  border-top-color: #ff6b00;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more-text {
  color: #bbb;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.btn-create {
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: none;
  transition: opacity 0.15s, transform 0.15s;
}

.btn-create:active {
  opacity: 0.85;
  transform: scale(0.98);
}
