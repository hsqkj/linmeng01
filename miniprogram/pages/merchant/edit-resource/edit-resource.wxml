<!-- 商家端资源编辑页 -->
<view class="edit-resource">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text>← 返回</text>
    </view>
    <text class="nav-title">编辑资源</text>
    <view class="nav-save" bindtap="saveResource">
      <text>保存</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 表单内容 -->
  <scroll-view scroll-y class="form-content" wx:else>
    <!-- 资源类型 -->
    <view class="form-section">
      <view class="section-title">资源类型</view>
      <view class="type-selector">
        <text class="type-name">{{resourceTypeName}}</text>
        <text class="type-tip">（类型创建后不可修改）</text>
      </view>
    </view>

    <!-- 资源标题 -->
    <view class="form-section">
      <view class="section-title">资源标题 <text class="required">*</text></view>
      <input 
        class="input-field" 
        placeholder="请输入资源标题" 
        value="{{form.title}}"
        bindinput="onTitleInput"
        maxlength="50"
      />
      <text class="char-count">{{form.title.length || 0}}/50</text>
    </view>

    <!-- 根据类型显示不同字段 -->
    <!-- 资金赞助 -->
    <view class="form-section" wx:if="{{resourceTypeName === '资金赞助'}}">
      <view class="section-title">赞助金额范围</view>
      <view class="amount-row">
        <input 
          class="input-field amount-input" 
          type="number" 
          placeholder="最低金额" 
          value="{{form.min_amount}}"
          bindinput="onMinAmountInput"
        />
        <text class="amount-sep">~</text>
        <input 
          class="input-field amount-input" 
          type="number" 
          placeholder="最高金额" 
          value="{{form.max_amount}}"
          bindinput="onMaxAmountInput"
        />
        <text class="amount-unit">元</text>
      </view>
    </view>

    <!-- 物资捐赠 -->
    <view class="form-section" wx:if="{{resourceTypeName === '物资捐赠'}}">
      <view class="section-title">物资清单 <text class="required">*</text></view>
      <textarea 
        class="textarea-field" 
        placeholder="请详细列出可提供的物资，如：矿泉水500ml，可提供500瓶" 
        value="{{form.goodsDetail}}"
        bindinput="onGoodsDetailInput"
        maxlength="500"
      />
      <view class="form-row">
        <view class="row-item">
          <text class="row-label">领取方式</text>
          <picker bindchange="onPickupWayChange" value="{{pickupWayIndex}}" range="{{pickupWays}}">
            <text class="picker-value">{{pickupWays[pickupWayIndex]}}</text>
          </picker>
        </view>
      </view>
    </view>

    <!-- 志愿服务 -->
    <view class="form-section" wx:if="{{resourceTypeName === '志愿服务'}}">
      <view class="section-title">可派遣人数</view>
      <view class="number-row">
        <input 
          class="input-field number-input" 
          type="number" 
          placeholder="人数" 
          value="{{form.staff_count}}"
          bindinput="onStaffCountInput"
        />
        <text class="number-unit">人</text>
      </view>
      <view class="section-title" style="margin-top: 30rpx;">单次服务时长</view>
      <view class="number-row">
        <input 
          class="input-field number-input" 
          type="digit" 
          placeholder="时长" 
          value="{{form.work_duration}}"
          bindinput="onWorkDurationInput"
        />
        <text class="number-unit">小时</text>
      </view>
    </view>

    <!-- 专业服务 -->
    <view class="form-section" wx:if="{{resourceTypeName === '专业服务'}}">
      <view class="section-title">服务区域</view>
      <picker bindchange="onServiceScopeChange" value="{{serviceScopeIndex}}" range="{{serviceScopes}}">
        <text class="picker-value">{{serviceScopes[serviceScopeIndex]}}</text>
      </picker>
      <view class="section-title" style="margin-top: 30rpx;">资质证明</view>
      <textarea 
        class="textarea-field" 
        placeholder="请描述您的资质证明" 
        value="{{form.certification}}"
        bindinput="onCertificationInput"
      />
    </view>

    <!-- 详细介绍 -->
    <view class="form-section">
      <view class="section-title">详细介绍 <text class="required">*</text></view>
      <textarea 
        class="textarea-field textarea-large" 
        placeholder="全面介绍您的资源优势、使用方式、适合场景等" 
        value="{{form.content}}"
        bindinput="onContentInput"
        maxlength="1000"
      />
      <text class="char-count">{{form.content.length || 0}}/1000</text>
    </view>

    <!-- 资源标签 -->
    <view class="form-section">
      <view class="section-title">资源标签</view>
      <view class="tags-grid">
        <text 
          class="tag {{form.tags.includes(item) ? 'tag-selected' : ''}}" 
          wx:for="{{tagOptions}}" 
          wx:key="index"
          bindtap="toggleTag"
          data-tag="{{item}}"
        >{{item}}</text>
      </view>
    </view>

    <!-- 有效期 -->
    <view class="form-section">
      <view class="section-title">有效期至</view>
      <picker mode="date" bindchange="onValidUntilChange" value="{{form.valid_until}}">
        <view class="date-picker">
          <text>{{form.valid_until || '请选择日期'}}</text>
        </view>
      </picker>
    </view>

    <!-- 期望回报 -->
    <view class="form-section">
      <view class="section-title">期望回报</view>
      <view class="tags-grid">
        <text 
          class="tag tag-warning {{form.expectedRewards.includes(item) ? 'tag-selected' : ''}}" 
          wx:for="{{rewardOptions}}" 
          wx:key="index"
          bindtap="toggleReward"
          data-reward="{{item}}"
        >{{item}}</text>
      </view>
      <textarea 
        class="textarea-field" 
        style="margin-top: 20rpx;"
        placeholder="请描述您期望获得的回报" 
        value="{{form.expectedRewardDesc}}"
        bindinput="onExpectedRewardDescInput"
      />
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="btn-submit" bindtap="submitResource" loading="{{submitting}}">提交审核</button>
    </view>
  </scroll-view>
</view>
