/* 商家端会员中心 */
.member-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 当前等级卡片 */
.current-level-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #409EFF, #66b1ff);
  color: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.level-badge {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  background: rgba(255,255,255,0.3);
  margin-right: 30rpx;
}

.level-info {
  flex: 1;
}

.level-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.level-expire {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 区块卡片 */
.section-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 等级对比 */
.level-compare {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.level-col {
  flex: 1;
  min-width: 280rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  background: #fafafa;
}

.level-col.current {
  background: linear-gradient(to bottom, #f0f9ff, #e8f4ff);
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.2);
}

.lv-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.lv-badge-sm {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
}

.lv-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin: 12rpx 0 8rpx;
}

.lv-fee {
  font-size: 28rpx;
  color: #E6A23C;
  font-weight: bold;
}

.lv-benefits {
  min-height: 80rpx;
}

.benefit-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  padding: 4rpx 0;
}

.level-action {
  margin-top: 16rpx;
  text-align: center;
  padding: 12rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #f0f0f0;
  color: #999;
}

.level-action.upgrade {
  background: #409EFF;
  color: #fff;
}

/* 缴费记录 */
.payment-list {
  margin-top: 16rpx;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-info {
  flex: 1;
}

.payment-time {
  display: block;
  font-size: 28rpx;
  color: #333;
}

.payment-level {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.payment-right {
  text-align: right;
}

.payment-amount {
  display: block;
  font-size: 30rpx;
  color: #E6A23C;
  font-weight: bold;
}

.payment-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-top: 6rpx;
  display: inline-block;
}

.payment-status.success {
  background: #f0f9eb;
  color: #67C23A;
}

.payment-status.pending {
  background: #fdf6ec;
  color: #E6A23C;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
