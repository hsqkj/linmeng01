/* 商家端消息中心样式 */

.messages-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.nav-back {
  font-size: 28rpx;
  color: #409EFF;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 标签页 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #409EFF;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #409EFF;
  border-radius: 2rpx;
}

.tab-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  background: #F56C6C;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  text-align: center;
}

/* 消息列表 */
.message-list {
  height: calc(100vh - 200rpx);
  padding: 20rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.message-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.type {
  font-size: 24rpx;
  color: #909399;
}

.status-badge {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  color: #fff;
}

.status-0 { background: #E6A23C; }
.status-1 { background: #67C23A; }
.status-2 { background: #909399; }
.status-3 { background: #409EFF; }
.comment-badge { background: #E6A23C; }

.card-content {
  font-size: 28rpx;
  color: #606266;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #909399;
}

.demand-ref {
  font-size: 24rpx;
  color: #409EFF;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-reply {
  padding: 12rpx 32rpx;
  background: #409EFF;
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  border: none;
}

/* 回复列表 */
.reply-list {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-top: 16rpx;
}

.reply-item {
  border-bottom: 1rpx solid #eee;
  padding-bottom: 12rpx;
  margin-bottom: 12rpx;
}

.reply-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
  margin-bottom: 0;
}

.reply-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.reply-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #409EFF;
}

.reply-tag {
  padding: 4rpx 12rpx;
  background: #67C23A;
  color: #fff;
  font-size: 20rpx;
  border-radius: 10rpx;
}

.reply-time {
  font-size: 22rpx;
  color: #909399;
  margin-left: auto;
}

.reply-text {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.5;
}

/* 系统通知 */
.system-card {
  position: relative;
}

.system-card.unread {
  border-left: 6rpx solid #409EFF;
}

.system-tag {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  color: #fff;
}

.tag-info { background: #409EFF; }
.tag-warning { background: #E6A23C; }
.tag-success { background: #67C23A; }
.tag-primary { background: #909399; }
.tag-default { background: #909399; }

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 12rpx 0;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #F56C6C;
  border-radius: 50%;
  margin-left: auto;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
