/* 商家端注册页样式 */

.register-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
}

.nav-back {
  font-size: 28rpx;
  color: #fff;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.form-content {
  height: calc(100vh - 100rpx);
  padding: 30rpx 20rpx 40rpx;
}

/* 步骤指示器 */
.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}

.step-item.active {
  color: #fff;
}

.step-item.done {
  color: #c8f7dc;
}

.step-num {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
}

.step-item.active .step-num {
  background: #fff;
  color: #11998e;
}

.step-item.done .step-num {
  background: #67C23A;
  color: #fff;
}

.step-line {
  width: 100rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #fff;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  margin-top: 30rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.required {
  color: #F56C6C;
}

.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.region-value {
  color: #333;
}

.code-row {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.btn-code {
  width: 220rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #11998e;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
  padding: 0;
}

.btn-code.disabled {
  background: #ccc;
}

.textarea-field {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.agreement {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.agreement-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 10rpx;
}

.link {
  color: #11998e;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-prev {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-submit {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: #11998e;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-submit[disabled] {
  background: #ccc;
}

.btn-next {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #11998e;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  margin-top: 40rpx;
}

.skip-tip {
  text-align: center;
  margin-top: 30rpx;
}

.skip-tip text {
  font-size: 26rpx;
  color: #999;
}

.footer-link {
  text-align: center;
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.link-text {
  color: #fff;
  text-decoration: underline;
  margin-left: 10rpx;
}
