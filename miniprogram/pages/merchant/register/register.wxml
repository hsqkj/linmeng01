<!-- 商家端注册页 -->
<view class="register-page">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text>← 返回</text>
    </view>
    <text class="nav-title">商家入驻</text>
    <view style="width: 100rpx;"></view>
  </view>

  <scroll-view scroll-y class="form-content">
    <!-- 步骤指示器 -->
    <view class="step-bar">
      <view class="step-item {{currentStep >= 1 ? 'active' : ''}} {{currentStep > 1 ? 'done' : ''}}">
        <view class="step-num">{{currentStep > 1 ? '✓' : '1'}}</view>
        <text>基本信息</text>
      </view>
      <view class="step-line {{currentStep > 1 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 2 ? 'active' : ''}}">
        <view class="step-num">2</view>
        <text>完善资料</text>
      </view>
    </view>

    <!-- 第一步：基本信息 -->
    <view class="form-section" wx:if="{{currentStep === 1}}">
      <view class="section-title">商家/企业名称 <text class="required">*</text></view>
      <input 
        class="input-field" 
        placeholder="请输入商家/企业名称" 
        value="{{form.company_name}}"
        bindinput="onCompanyNameInput"
      />

      <view class="section-title">行业分类 <text class="required">*</text></view>
      <picker bindchange="onIndustryChange" value="{{industryIndex}}" range="{{industries}}">
        <view class="picker-value">{{industries[industryIndex] || '请选择行业分类'}}</view>
      </picker>

      <view class="section-title">联系人姓名 <text class="required">*</text></view>
      <input 
        class="input-field" 
        placeholder="请输入联系人姓名" 
        value="{{form.contact_name}}"
        bindinput="onContactNameInput"
      />

      <view class="section-title">手机号 <text class="required">*</text></view>
      <input 
        class="input-field" 
        type="number" 
        maxlength="11" 
        placeholder="请输入手机号" 
        value="{{form.phone}}"
        bindinput="onPhoneInput"
      />

      <view class="section-title">验证码 <text class="required">*</text></view>
      <view class="code-row">
        <input 
          class="input-field code-input" 
          type="number" 
          maxlength="6" 
          placeholder="请输入验证码" 
          value="{{form.code}}"
          bindinput="onCodeInput"
        />
        <button class="btn-code {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode" disabled="{{countdown > 0}}">
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </button>
      </view>

      <view class="section-title">登录密码 <text class="required">*</text></view>
      <input 
        class="input-field" 
        type="password" 
        placeholder="设置登录密码（6-20位）" 
        value="{{form.password}}"
        bindinput="onPasswordInput"
      />

      <view class="section-title">确认密码 <text class="required">*</text></view>
      <input 
        class="input-field" 
        type="password" 
        placeholder="再次输入密码" 
        value="{{form.confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />

      <button class="btn-next" bindtap="goStep2">下一步</button>
    </view>

    <!-- 第二步：完善资料 -->
    <view class="form-section" wx:if="{{currentStep === 2}}">
      <view class="section-title">企业规模</view>
      <picker bindchange="onScaleChange" value="{{scaleIndex}}" range="{{scales}}">
        <view class="picker-value">{{scales[scaleIndex] || '请选择企业规模'}}</view>
      </picker>

      <view class="section-title">所在行政区划 <text class="required">*</text></view>
      <picker mode="region" bindchange="onRegionChange" value="{{region}}">
        <view class="picker-value region-value">
          {{region[0] || '请选择'}}{{region[1] ? ' - ' + region[1] : ''}}{{region[2] ? ' - ' + region[2] : ''}}
        </view>
      </picker>

      <view class="section-title">企业详细地址</view>
      <input 
        class="input-field" 
        placeholder="请输入企业详细地址（选填）" 
        value="{{form.address}}"
        bindinput="onAddressInput"
      />

      <view class="section-title">企业简介</view>
      <textarea 
        class="textarea-field" 
        placeholder="请简要介绍您的企业（选填）" 
        value="{{form.description}}"
        bindinput="onDescriptionInput"
        maxlength="500"
      />

      <view class="agreement">
        <checkbox-group bindchange="onAgreementChange">
          <label>
            <checkbox value="agree" color="#67C23A" checked="{{form.agree}}" />
            <text class="agreement-text">我已阅读并同意<text class="link">《用户协议》</text>和<text class="link">《隐私政策》</text></text>
          </label>
        </checkbox-group>
      </view>

      <view class="btn-group">
        <button class="btn-prev" bindtap="goStep1">上一步</button>
        <button class="btn-submit" bindtap="submitRegister" loading="{{submitting}}" disabled="{{!form.agree}}">立即注册</button>
      </view>

      <view class="skip-tip">
        <text bindtap="skipStep2">跳过此步，稍后补充 →</text>
      </view>
    </view>

    <!-- 已有账号 -->
    <view class="footer-link">
      <text>已有账号？</text>
      <text class="link-text" bindtap="goLogin">立即登录</text>
    </view>
  </scroll-view>
</view>
