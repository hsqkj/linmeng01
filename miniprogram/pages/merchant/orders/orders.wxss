/* 商家端订单管理样式 */

.orders-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 30rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.order-status.pending {
  background: #fff3e6;
  color: #FF6B00;
}

.order-status.paid {
  background: #e6f7ed;
  color: #07c160;
}

.order-status.completed {
  background: #e6f7ed;
  color: #07c160;
}

.order-content {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.resource-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.resource-type {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B00;
}

.time {
  font-size: 24rpx;
  color: #999999;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty text {
  font-size: 28rpx;
  color: #999999;
}
