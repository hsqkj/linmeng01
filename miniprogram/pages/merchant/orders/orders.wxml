<!-- 商家端订单管理 -->
<view class="orders-page">
  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" bindtap="viewDetail" data-id="{{item.id}}">
        <view class="order-header">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="order-content">
          <text class="resource-title">{{item.resourceTitle}}</text>
          <text class="resource-type">{{item.resourceType}}</text>
        </view>
        <view class="order-footer">
          <text class="amount">¥{{item.amount}}</text>
          <text class="time">{{item.createTime}}</text>
        </view>
      </view>
    </block>

    <view wx:if="{{orders.length === 0}}" class="empty">
      <text>暂无订单</text>
    </view>
  </view>
</view>
