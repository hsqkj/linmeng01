/* 商家端个人中心样式 */

.merchant-profile {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 用户信息卡片 */
.profile-header {
  background: linear-gradient(135deg, #FF6B00, #ff8533);
  padding: 60rpx 30rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: #ffffff;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.info {
  flex: 1;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.company {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.phone {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
}

.edit-btn {
  padding: 16rpx 28rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
}

.edit-btn text {
  font-size: 26rpx;
  color: #ffffff;
}

/* 会员卡片 */
.member-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 40rpx;
}

.member-left {
  display: flex;
  flex-direction: column;
}

.member-title {
  font-size: 24rpx;
  color: #999999;
}

.member-level {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B00;
  margin-top: 8rpx;
}

.member-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.member-expire {
  font-size: 24rpx;
  color: #999999;
}

.member-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF6B00, #ff8533);
  border-radius: 30rpx;
  margin-top: 12rpx;
}

.member-btn text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 菜单列表 */
.menu-list {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  background: #fff5eb;
  border-radius: 12rpx;
  padding: 12rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.logout-icon {
  background: #fff0f0;
}

.menu-text {
  flex: 1;
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #333333;
}

.logout-text {
  color: #ff4d4f;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.3;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #eeeeee;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-item image {
  width: 44rpx;
  height: 44rpx;
}

.nav-item text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.nav-item.active text {
  color: #FF6B00;
}
