/* 商家端首页样式 */
.merchant-home {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  background: #fff;
}

.user-detail .company-name {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.member-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-tag {
  background: rgba(255,255,255,0.25);
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.member-expire {
  color: rgba(255,255,255,0.8);
  font-size: 20rpx;
}

.btn-edit {
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.4);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

/* 数据统计 */
.stats-row {
  display: flex;
  background: #fff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #eee;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.action-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon image {
  width: 48rpx;
  height: 48rpx;
}

.action-icon.orange { background: #fff3e6; }
.action-icon.blue { background: #e6f3ff; }
.action-icon.green { background: #e6fff0; }
.action-icon.gold { background: #fff9e6; }

/* 区块 */
.section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #999;
  font-size: 24rpx;
}

.section-more image {
  width: 28rpx;
  height: 28rpx;
}

/* 需求列表 */
.demand-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.demand-card {
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.demand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.demand-type {
  background: #ff6b00;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.demand-time {
  font-size: 22rpx;
  color: #999;
}

.demand-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.demand-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.demand-meta image {
  width: 24rpx;
  height: 24rpx;
}

/* 平台统计 */
.platform-stats {
  display: flex;
  gap: 20rpx;
}

.platform-item {
  flex: 1;
  background: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

.platform-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b00;
  margin-bottom: 8rpx;
}

.platform-label {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
