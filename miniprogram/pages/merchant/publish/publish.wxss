/* 商家端发布资源 */
.publish-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 步骤条 */
.steps-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 40rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.4;
}

.step-item.active {
  opacity: 1;
}

.step-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.step-item.active .step-circle {
  background: linear-gradient(135deg, #ff6b00, #ff8533);
}

.step-item.completed .step-circle {
  background: #67C23A;
}

.step-text {
  font-size: 22rpx;
  color: #999;
}

.step-item.active .step-text {
  color: #333;
  font-weight: 500;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #ddd;
  margin: 0 16rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #ff8533;
}

/* 内容区 */
.content {
  padding: 20rpx;
}

.step-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 提示框 */
.tip-box {
  background: linear-gradient(135deg, #fff9f0, #fff);
  border: 1rpx solid #ffe4b5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #E6A23C;
  margin-bottom: 24rpx;
}

/* 类型卡片 */
.type-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.type-card {
  position: relative;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  transition: all 0.2s;
}

.type-card.active {
  border-color: #ff6b00;
  background: linear-gradient(to bottom, #fff9f0, #fff);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.type-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.check-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: #ff6b00;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 0 16rpx 0 12rpx;
}

/* 表单项 */
.form-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #F56C6C;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea.tall {
  height: 200rpx;
}

.field-tip {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 标签选择器 */
.tag-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selector-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
}

.selector-tag.active {
  border-color: #ff6b00;
  background: #fff3e0;
  color: #ff6b00;
}

/* 单选组 */
.radio-group {
  display: flex;
  gap: 30rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-btn text {
  color: #fff;
  font-size: 32rpx;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  color: #ddd;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

/* 回报示例 */
.reward-examples {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.example-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.example-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

/* 预览卡片 */
.preview-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-type {
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.preview-status {
  font-size: 26rpx;
  color: #E6A23C;
}

.preview-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.preview-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.preview-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preview-images image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
}

/* 协议勾选 */
.agreement-check {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.agreement-check text {
  font-size: 26rpx;
  color: #666;
}

.agreement-check .link {
  color: #409EFF;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-prev {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-next {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b00, #ff8533);
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-next.full {
  flex: none;
  width: 100%;
}

.btn-submit {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #67C23A, #85ce61);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-submit.full {
  flex: none;
  width: 100%;
}

.btn-submit[disabled] {
  background: #ccc;
  color: #fff;
}
