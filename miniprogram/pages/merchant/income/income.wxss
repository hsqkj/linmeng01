/* 商家端收益管理样式 */

.income-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.summary-card {
  background: linear-gradient(135deg, #FF6B00, #ff8533);
  padding: 50rpx 30rpx;
  color: #ffffff;
}

.title {
  font-size: 28rpx;
  opacity: 0.8;
}

.amount {
  font-size: 64rpx;
  font-weight: 700;
  margin-top: 16rpx;
  display: block;
}

.buttons {
  margin-top: 30rpx;
}

.btn-withdraw {
  width: 200rpx;
  height: 72rpx;
  background: #ffffff;
  color: #FF6B00;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 36rpx;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  border: none;
}

.btn-withdraw::after {
  border: none;
}

.other-stats {
  display: flex;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.7;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.section {
  background: #ffffff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.record-list {
  margin-top: 24rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 28rpx;
  color: #333333;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.record-amount.income {
  color: #07c160;
}

.record-amount.withdraw {
  color: #ff4d4f;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty text {
  font-size: 26rpx;
  color: #999999;
}
