/* 招商大使端登录样式 */

.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #D4A017 0%, #e6b422 100%);
  padding: 100rpx 50rpx 50rpx;
}

/* 顶部 */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.ambassador-logo {
  background: linear-gradient(135deg, #D4A017, #FFD700);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-top: 30rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

/* 登录内容 */
.login-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

/* 微信登录 */
.wechat-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
}

.btn-wechat::after {
  border: none;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.login-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 24rpx;
}

/* 其他登录方式 */
.other-login {
  margin-top: 60rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #eeeeee;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.login-options {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.login-option {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.option-icon {
  width: 80rpx;
  height: 80rpx;
  background: #fff5eb;
  border-radius: 50%;
  padding: 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.ambassador-icon {
  background: #fffbe6;
}

.login-option text {
  font-size: 24rpx;
  color: #666666;
}

/* 用户协议 */
.agreement {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
}

.agreement-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
  margin-left: 12rpx;
}

.link {
  color: #D4A017;
}

/* 手机号登录弹窗 */
.phone-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.phone-modal.show {
  display: flex;
}

.phone-modal-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-group input {
  height: 88rpx;
  border: 2rpx solid #dddddd;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.verify-group {
  display: flex;
  gap: 20rpx;
}

.verify-group input {
  flex: 1;
}

.btn-code {
  width: 220rpx;
  height: 88rpx;
  background: #fffbe6;
  color: #D4A017;
  font-size: 26rpx;
  border: none;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn-code.disabled {
  color: #999999;
  background: #f5f5f5;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #D4A017, #FFD700);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  margin-top: 20rpx;
}

.btn-login::after {
  border: none;
}
