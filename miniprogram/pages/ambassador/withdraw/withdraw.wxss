/* 提现页面样式 */
.withdraw-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.balance-card {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 50rpx 30rpx;
  text-align: center;
}

.balance-label {
  display: block;
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.balance-value {
  display: block;
  color: #ffd700;
  font-size: 60rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.balance-hint {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
}

.withdraw-form {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.input-prefix {
  font-size: 36rpx;
  color: #333;
  margin-right: 10rpx;
}

.form-input {
  flex: 1;
  padding: 24rpx 0;
  font-size: 32rpx;
}

.quick-amounts {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.quick-btn {
  background: #f5f5f5;
  color: #666;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.account-card {
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
}

.account-type {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.account-info {
  font-size: 24rpx;
  color: #999;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.btn-submit {
  background: linear-gradient(135deg, #d4a017, #b8860b);
  color: #fff;
  padding: 28rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 20rpx;
}

.section {
  background: #fff;
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-amount {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-status {
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
