/* 招商大使端首页样式 */
.ambassador-home {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 欢迎横幅 */
.welcome-banner {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #d4a017;
  background: #fff;
}

.amb-name {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.amb-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.amb-level {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.amb-code {
  color: rgba(255,255,255,0.6);
  font-size: 20rpx;
}

.btn-qrcode {
  background: #d4a017;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border: none;
}

.btn-qrcode image {
  width: 28rpx;
  height: 28rpx;
}

/* 核心指标 */
.stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-icon {
  font-size: 40rpx;
}

.stat-val {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-card.blue .stat-val { color: #409eff; }
.stat-card.green .stat-val { color: #67c23a; }
.stat-card.yellow .stat-val { color: #e6a23c; }
.stat-card.orange .stat-val { color: #d4a017; }

/* 区块卡片 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #d4a017;
  font-size: 24rpx;
}

.section-more image {
  width: 28rpx;
  height: 28rpx;
}

/* 收益概况 */
.income-card .income-header {
  margin-bottom: 20rpx;
}

.income-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.income-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}

.income-item:last-child {
  border-bottom: none;
}

.income-label {
  font-size: 28rpx;
  color: #606266;
}

.income-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.income-val.total {
  font-size: 36rpx;
  color: #d4a017;
}

.income-val.highlight {
  color: #67c23a;
}

.btn-withdraw {
  background: linear-gradient(135deg, #d4a017, #b8860b);
  color: #fff;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 20rpx;
  border: none;
}

/* 快速操作 */
.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 16rpx;
}

.qa-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
}

.qa-item image {
  width: 48rpx;
  height: 48rpx;
}

.qa-item text {
  font-size: 22rpx;
  color: #606266;
}

/* 商家列表 */
.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.merchant-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}

.merchant-item:last-child {
  border-bottom: none;
}

.merchant-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.merchant-name {
  font-size: 28rpx;
  color: #333;
}

.merchant-level {
  background: #fff3e6;
  color: #ff6b00;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.merchant-time {
  font-size: 22rpx;
  color: #999;
}

/* 提成政策 */
.policy-card {
  background: #fff;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

.level-name {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.level-rate {
  color: #ffd700;
  font-size: 28rpx;
  font-weight: bold;
}

.policy-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.policy-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #eee;
}

.policy-row:last-child {
  border-bottom: none;
}

.policy-label {
  font-size: 26rpx;
  color: #606266;
}

.policy-value {
  font-size: 26rpx;
  color: #d4a017;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
