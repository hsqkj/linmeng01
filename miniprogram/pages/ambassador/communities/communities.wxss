/* 我的社区样式 */
.communities-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.community-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.community-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.community-info {
  margin-bottom: 16rpx;
}

.community-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.community-address {
  font-size: 24rpx;
  color: #999;
}

.community-stats {
  display: flex;
  gap: 30rpx;
}

.community-stats .stat {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-state text {
  display: block;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.btn-add {
  background: linear-gradient(135deg, #d4a017, #b8860b);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: none;
}
