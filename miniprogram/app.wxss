/** 邻盟小程序全局样式 **/

/* 全局字体颜色 */
page {
  font-size: 28rpx;
  color: #333333;
  background-color: #f5f5f5;
}

/* 容器 */
.container {
  padding: 30rpx;
}

/* ==================== 卡片 ==================== */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.15s, box-shadow 0.15s;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.03);
}

/* ==================== 标题 & 文字 ==================== */
.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

/* 文字层级 */
.text-lg { font-size: 32rpx; }
.text-base { font-size: 28rpx; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }

/* ==================== 按钮 ==================== */
.btn-primary {
  background: linear-gradient(135deg, #409EFF, #66b1ff);
  color: #ffffff;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  transition: opacity 0.15s, transform 0.15s;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-default {
  background: #ffffff;
  color: #409EFF;
  border: 2rpx solid #409EFF;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  transition: opacity 0.15s, transform 0.15s;
}

.btn-default:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ==================== 标签 ==================== */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: #ecf5ff;
  color: #409EFF;
}

.tag-success {
  background: #f0f9eb;
  color: #67c23a;
}

.tag-warning {
  background: #fdf6ec;
  color: #e6a23c;
}

.tag-danger {
  background: #fef0f0;
  color: #f56c6c;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  text-align: center;
}

.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #999;
}

.empty-state .empty-desc {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 12rpx;
}

/* ==================== 加载状态 ==================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-state .loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #409EFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

.loading-state .loading-text {
  font-size: 26rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ==================== 间距 ==================== */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* ==================== Flex布局 ==================== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { justify-content: center; align-items: center; }
.flex-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* ==================== 文字颜色 ==================== */
.text-center { text-align: center; }
.text-primary { color: #409EFF; }
.text-success { color: #67c23a; }
.text-warning { color: #e6a23c; }
.text-danger { color: #f56c6c; }
.text-gray { color: #999999; }
.text-bold { font-weight: 600; }
